# ============================================================
# Chatbot Whisper — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── API Keys ────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key

# ── Security ────────────────────────────────────────────────
# JWT secret key (generate with: openssl rand -base64 48)
JWT_SECRET=generate-a-random-48-byte-base64-key-here

# H2 database password (change this in production!)
H2DB_PASSWORD=chatbot_h2_secure_2024

# ── Domain ──────────────────────────────────────────────────
DOMAIN_NAME=harshdeep.tech

# ── Optional Tuning ────────────────────────────────────────
BACKEND_PORT=8081
